{
  "$id": "urn:dnd-ai:contracts:v3:PasswordResetConfirm",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "code": {
      "pattern": "^[0-9]{6}$",
      "type": "string"
    },
    "email": {
      "minLength": 1,
      "type": "string"
    },
    "newPassword": {
      "type": "string"
    }
  },
  "required": [
    "email",
    "code",
    "newPassword"
  ],
  "title": "PasswordResetConfirm",
  "type": "object",
  "x-dnd-ai-contract-kind": "request",
  "x-dnd-ai-contract-version": "3.0.0"
}
