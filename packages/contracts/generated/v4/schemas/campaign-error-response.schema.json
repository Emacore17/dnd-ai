{
  "$id": "urn:dnd-ai:contracts:v4:CampaignErrorResponse",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "campaign.request_invalid",
            "identity.session_invalid",
            "campaign.not_found",
            "campaign.unavailable"
          ],
          "type": "string"
        },
        "message": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string"
        },
        "requestId": {
          "description": "Server-owned canonical lowercase UUIDv4 request ID.",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message",
        "requestId",
        "retryable"
      ],
      "type": "object"
    }
  },
  "required": [
    "error"
  ],
  "title": "CampaignErrorResponse",
  "type": "object",
  "x-dnd-ai-contract-kind": "response",
  "x-dnd-ai-contract-version": "4.0.0"
}
