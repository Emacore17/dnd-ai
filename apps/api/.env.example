# Copy to apps/api/.env.local and replace secret-bearing sentinels locally.
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=3001
API_DATABASE_URL=<set-in-local-env-file>
API_REDIS_URL=<set-in-local-env-file>
# Browser-facing web origin accepted by the API Origin policy.
API_PUBLIC_ORIGIN=http://127.0.0.1:3000
API_AUTH_PASSWORD_PEPPER_BASE64=<set-in-local-env-file>
API_AUTH_PASSWORD_PEPPER_VERSION=1
API_AUTH_CHALLENGE_HMAC_KEY_BASE64=<set-in-local-env-file>
API_AUTH_CHALLENGE_KEY_VERSION=1
API_AUTH_SESSION_HMAC_KEY_BASE64=<set-in-local-env-file>
API_AUTH_SESSION_KEY_VERSION=1
API_AUTH_RESET_HMAC_KEY_BASE64=<set-in-local-env-file>
API_AUTH_RESET_KEY_VERSION=1
API_AUTH_SUBJECT_HASH_KEY_BASE64=<set-in-local-env-file>
API_AUTH_BFF_ASSERTION_KEY_BASE64=<set-in-local-env-file>
API_SENTRY_DSN=
