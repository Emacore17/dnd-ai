{
  "name": "@dnd-ai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "start": "node dist/start.js",
    "start:local": "node --env-file=.env.local dist/start.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-ai/config": "workspace:*",
    "@dnd-ai/observability": "workspace:*",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3"
  }
}
