{
  "name": "@dnd-ai/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "analyze": "next experimental-analyze --output",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test:component": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:functional": "playwright test --config playwright.config.ts game-shell.spec.ts",
    "test:e2e:performance": "playwright test --config playwright.config.ts game-shell.performance.spec.ts --project=mobile-390 --repeat-each=3 --retries=0",
    "test:e2e:update": "playwright test --config playwright.config.ts --update-snapshots"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "geist": "1.7.2",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "radix-ui": "1.6.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "4.13.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "use-stick-to-bottom": "1.1.6",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "vitest": "4.1.10"
  }
}
