# Copy to apps/worker/.env.local and replace secret-bearing sentinels locally.
APP_ENV=local
WORKER_DATABASE_URL=<set-in-local-env-file>
WORKER_REDIS_URL=<set-in-local-env-file>
WORKER_AUTH_CHALLENGE_HMAC_KEY_BASE64=<set-in-local-env-file>
WORKER_AUTH_CHALLENGE_KEY_VERSION=1
WORKER_EMAIL_DELIVERY_MODE=fake
WORKER_SMTP_HOST=
WORKER_SMTP_PORT=
WORKER_SMTP_SECURE=
WORKER_SMTP_USERNAME=
WORKER_SMTP_PASSWORD=
WORKER_SMTP_FROM=
WORKER_SENTRY_DSN=
