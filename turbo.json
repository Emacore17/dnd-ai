{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "eslint.config.mjs",
    "tsconfig.base.json",
    "tsconfig.node.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
